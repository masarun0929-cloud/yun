# Cloudflare Dashboard > Account homeで確認するAccount ID。
CLOUDFLARE_ACCOUNT_ID=replace_with_cloudflare_account_id

# Cloudflare Dashboard > D1 > 対象databaseで確認するDatabase ID。
CLOUDFLARE_D1_DATABASE_ID=replace_with_d1_database_id

# Cloudflare Dashboard > My Profile > API Tokensで作るD1編集用token。
# 権限の目安: Account / D1 / Edit。
# GitHub、公開HTML、チャットには貼らないでください。
CLOUDFLARE_API_TOKEN=replace_with_cloudflare_api_token

# Optional. Keep the server bound locally and expose it with Tailscale Serve.
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8788

# Optional defense in depth for the browser UI/API.
# 設定すると、管理画面のAPI呼び出しにこの値が必要になります。
ADMIN_TOKEN=replace_with_private_admin_password

# Optional public-facing labels used by the local admin UI and genre inference.
ADMIN_TITLE=さざなみゆん 歌枠管理

# カンマ区切り。曲名/アーティストに含まれたら「オリジナル」と推定します。
ORIGINAL_GENRE_KEYWORDS=さざなみゆん,ゆん,Sazanami Yun

# Optional. Paste the integrated key/genre spreadsheet tab URL here
# if you want the admin UI to sync without entering the URL each time.
KEY_REFERENCE_CSV_URL=https://docs.google.com/spreadsheets/d/your_spreadsheet_id/edit?gid=your_gid#gid=your_gid
